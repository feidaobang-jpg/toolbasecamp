<script>(function(){if(!("serviceWorker"in navigator))return;navigator.serviceWorker.getRegistrations().then(function(rs){if(!rs.length)return;Promise.all(rs.map(function(r){return r.unregister()})).then(function(){var k="tbc-sw-v3";if(!sessionStorage.getItem(k)){sessionStorage.setItem(k,"1");location.reload()}})})})();</script><style>body.portal-has-home-bar{padding-top:36px!important}#portal-home-bar{position:fixed;top:0;left:0;right:0;z-index:99999;height:36px;display:flex;align-items:center;padding:0 16px;background:#1e293b;border-bottom:1px solid #334155;box-sizing:border-box;font-family:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif}#portal-home-bar a{color:#e2e8f0;text-decoration:none;font-size:13px;font-weight:500;display:inline-flex;align-items:center;gap:6px}#portal-home-bar a:hover{color:#fff}</style><script defer>(function(){function i(){if(document.getElementById("portal-home-bar")||!document.body)return;var b=document.createElement("div");b.id="portal-home-bar";b.setAttribute("role","navigation");var a=document.createElement("a");a.href="https://toolbasecamp.com/";a.textContent="\u2190 Tool Basecamp";b.appendChild(a);document.body.classList.add("portal-has-home-bar");document.body.insertBefore(b,document.body.firstChild)}document.readyState==="loading"?document.addEventListener("DOMContentLoaded",i):i()})();</script>
