# Copy relevant lines to /etc/toolbasecamp-api.env on the VPS, then:
#   systemctl restart toolbasecamp-api
# Verify: curl -s http://127.0.0.1:8001/health

# --- DeepSeek (recipe text generation, recommended) ---
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# --- Qwen / DashScope: China (华北2 北京, cheaper) ---
# API Key MUST be created in 百炼 console → region 华北2（北京）
DASHSCOPE_API_KEY=sk-xxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-plus
# Cheaper vision: QWEN_VL_MODEL=qwen3-vl-flash
QWEN_MODEL=qwen-plus

# --- Qwen / DashScope: US (Virginia, if VPS is in US and you want lower RTT) ---
# DASHSCOPE_API_KEY=sk-xxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# QWEN_VL_MODEL=qwen3-vl-plus
# QWEN_MODEL=qwen3.7-plus-us

# Optional: force text provider (default auto = DeepSeek if key set)
# RECIPE_TEXT_PROVIDER=auto
