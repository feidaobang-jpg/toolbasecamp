# Copy relevant lines to /etc/toolbasecamp-api.env on the VPS, then:
#   systemctl restart toolbasecamp-api
# Verify: curl -s http://127.0.0.1:8001/health

# --- DeepSeek (recipe text + vision, recommended) ---
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_VL_MODEL=deepseek-v4-flash
# Optional: RECIPE_TEXT_PROVIDER=auto  RECIPE_VISION_PROVIDER=auto

# --- Qwen / DashScope (optional fallback for vision/text) ---
# Only needed if DeepSeek fails or RECIPE_*_PROVIDER=qwen
# DASHSCOPE_API_KEY=sk-xxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_VL_MODEL=qwen3-vl-flash
# QWEN_MODEL=qwen-plus
