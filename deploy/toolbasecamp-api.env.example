# Copy relevant lines to /etc/toolbasecamp-api.env on the VPS, then:
#   systemctl restart toolbasecamp-api
# Verify: curl -s http://127.0.0.1:8001/health

# --- DeepSeek (recipe text generation) ---
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# --- Qwen US / DashScope (image ingredient recognition + Wan I2V) ---
DASHSCOPE_API_KEY=sk-xxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen3-vl-plus
# Wan image-to-video (uses same DASHSCOPE_API_KEY; API root derived from BASE_URL)
# US Virginia default model: wan2.6-i2v-us ; China Beijing: wan2.6-i2v-flash
# WAN_I2V_MODEL=wan2.6-i2v-us
# WAN_DASHSCOPE_API_URL=https://dashscope-us.aliyuncs.com/api/v1
# Daily free runs per login user (admins unlimited). Keep low — each run costs real money.
WAN_I2V_LIMIT=2

# --- TianAPI 天行数据（生活模块：鸡汤/谜语/诗词等）---
# https://www.tianapi.com/
# NOTE: VPS must be able to reach apis.tianapi.com (海外机房常不通，需代理或国内跳板)
TIANAPI_KEY=xxxxxxxx
# TIANAPI_BASE=https://apis.tianapi.com
# TIANAPI_TIMEOUT=8

# --- Tencent Cloud (image OCR / enhance / ID photo) ---
# Console: https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=AKIDxxxxxxxx
TENCENT_SECRET_KEY=xxxxxxxx
TENCENT_REGION=ap-guangzhou
# Optional daily per-user limits (defaults shown). Admin accounts are exempt.
# ADMIN_EMAIL must match your login email (same as guestbook admin), default admin@toolbasecamp.com
# ADMIN_EMAIL=admin@toolbasecamp.com
# IMAGE_LIMIT_OCR_TEXT=30
# IMAGE_LIMIT_OCR_TABLE=20
# IMAGE_LIMIT_ENHANCE=20
# IMAGE_LIMIT_ID_PHOTO=10
# IMAGE_LIMIT_GENERAL_CUTOUT=15
# IMAGE_LIMIT_TO_PDF=20
# General cutout uses rembg (optional). After deploy:
#   /opt/toolbasecamp-api/venv/bin/pip install -r /opt/toolbasecamp-api/requirements-general-cutout.txt
#   systemctl restart toolbasecamp-api
# REMBG_MODEL=u2netp
